<Window x:Class="VoiceFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BONGA" Height="680" Width="1000" MinHeight="560" MinWidth="820"
        Icon="/Assets/bonga.ico"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}">
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF262635"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDim}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}">
            <DockPanel Margin="14,18,14,16">
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal" Margin="4,0,0,18">
                        <Ellipse Width="12" Height="12" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="BONGA" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Button Style="{StaticResource NavBtn}" Content="🏠  Home" Tag="Home" Click="Nav_Click"/>
                    <Button Style="{StaticResource NavBtn}" Content="🕘  History" Tag="History" Click="Nav_Click"/>
                    <Button Style="{StaticResource NavBtn}" Content="📖  Dictionary" Tag="Dictionary" Click="Nav_Click"/>
                    <Button Style="{StaticResource NavBtn}" Content="⚡  Snippets" Tag="Snippets" Click="Nav_Click"/>
                    <Button Style="{StaticResource NavBtn}" Content="⚙  Settings" Tag="Settings" Click="Nav_Click"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,12">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#FF6BCB77" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Ready" Style="{StaticResource Lbl}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="⏻  Quit BONGA" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Click="Quit_Click"/>
                    <TextBlock Text="The ✕ button keeps BONGA running in the tray." Style="{StaticResource Lbl}" FontSize="11" Margin="2,8,0,0"/>
                </StackPanel>
                <Grid/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="30,26,30,30">

                <!-- HOME -->
                <StackPanel x:Name="HomePanel">
                    <TextBlock Style="{StaticResource H1}" Text="Speak anywhere. Write faster."/>
                    <TextBlock x:Name="HotkeyHint" Style="{StaticResource Lbl}" FontSize="13" Margin="0,8,0,0"/>
                    <UniformGrid Columns="3" Margin="0,22,0,0">
                        <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock x:Name="StatDictations" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="dictations" Style="{StaticResource Lbl}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock x:Name="StatWords" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="words written" Style="{StaticResource Lbl}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock x:Name="StatSaved" Text="0 min" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="saved vs typing" Style="{StaticResource Lbl}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Speech model" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="ModelStatusText" Style="{StaticResource Lbl}" Margin="0,6,0,0"/>
                            <ProgressBar x:Name="ModelProgress" Height="8" Margin="0,12,0,0" Maximum="1" Visibility="Collapsed"/>
                            <Button x:Name="DownloadModelBtn" Content="Download model" Style="{StaticResource AccentButton}"
                                    HorizontalAlignment="Left" Margin="0,12,0,0" Click="DownloadModel_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Try it here" Style="{StaticResource H2}"/>
                            <TextBlock Text="Click into the box below, then hold your hotkey and speak." Style="{StaticResource Lbl}" Margin="0,4,0,10"/>
                            <TextBox Style="{StaticResource DarkTextBox}" Height="90" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- HISTORY -->
                <StackPanel x:Name="HistoryPanel" Visibility="Collapsed">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Clear all" Style="{StaticResource GhostButton}" Click="ClearHistory_Click"/>
                        <TextBlock Style="{StaticResource H1}" Text="History"/>
                    </DockPanel>
                    <TextBlock x:Name="HistoryEmptyText" Style="{StaticResource Lbl}" Margin="0,14,0,0"
                               Text="No dictations yet — hold your hotkey and start talking."/>
                    <ItemsControl x:Name="HistoryList" Margin="0,14,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" FontSize="13"/>
                                        <DockPanel Margin="0,8,0,0">
                                            <Button Content="Copy" DockPanel.Dock="Right" Style="{StaticResource GhostButton}"
                                                    Padding="10,4" FontSize="11" Click="CopyHistory_Click" Tag="{Binding}"/>
                                            <TextBlock Text="{Binding Meta}" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- DICTIONARY -->
                <StackPanel x:Name="DictionaryPanel" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource H1}" Text="Dictionary"/>
                    <TextBlock Style="{StaticResource Lbl}" Margin="0,6,0,0"
                               Text="Teach Flow your names, brands and jargon. Words below bias the recognizer; corrections rewrite words it keeps getting wrong."/>
                    <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Recognized words &amp; names" Style="{StaticResource H2}"/>
                            <DockPanel Margin="0,10,0,0">
                                <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Click="AddWord_Click"/>
                                <TextBox x:Name="NewWordBox" Style="{StaticResource DarkTextBox}" KeyDown="NewWordBox_KeyDown"/>
                            </DockPanel>
                            <ListBox x:Name="WordsList" Height="140" Margin="0,10,0,0"/>
                            <Button Content="Remove selected" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="RemoveWord_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Corrections (misheard → correct)" Style="{StaticResource H2}"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="RepFromBox" Style="{StaticResource DarkTextBox}"/>
                                <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource TextDimBrush}" Margin="10,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="RepToBox" Grid.Column="2" Style="{StaticResource DarkTextBox}"/>
                                <Button Grid.Column="3" Content="Add" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Click="AddRep_Click"/>
                            </Grid>
                            <ListBox x:Name="RepsList" Height="120" Margin="0,10,0,0" DisplayMemberPath="Display"/>
                            <Button Content="Remove selected" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="RemoveRep_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- SNIPPETS -->
                <StackPanel x:Name="SnippetsPanel" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource H1}" Text="Snippets"/>
                    <TextBlock Style="{StaticResource Lbl}" Margin="0,6,0,0"
                               Text="Say a trigger phrase and Flow inserts the full text. Example: say “insert my email” to paste your email signature."/>
                    <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Trigger phrase" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="SnipTriggerBox" Style="{StaticResource DarkTextBox}" Margin="0,4,0,10"/>
                            <TextBlock Text="Expands to" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="SnipExpansionBox" Style="{StaticResource DarkTextBox}" Margin="0,4,0,10" Height="80"
                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <Button Content="Add snippet" Style="{StaticResource AccentButton}" HorizontalAlignment="Left" Click="AddSnippet_Click"/>
                            <ListBox x:Name="SnippetsList" Height="150" Margin="0,14,0,0" DisplayMemberPath="Display"/>
                            <Button Content="Remove selected" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="RemoveSnippet_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- SETTINGS -->
                <StackPanel x:Name="SettingsPanel" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource H1}" Text="Settings"/>

                    <TextBlock Text="General" Style="{StaticResource H2}" Margin="0,18,0,8"/>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Dictation hotkey" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="HotkeyCombo" Width="280" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Microphone" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="MicCombo" Width="280" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Language" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="LangCombo" Width="280" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Speech model" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ModelCombo" Width="280" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Engine" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="EngineCombo" Width="280" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Text insertion" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="InsertCombo" Width="280" HorizontalAlignment="Left"/>
                    </DockPanel>

                    <TextBlock Text="Formatting" Style="{StaticResource H2}" Margin="0,16,0,8"/>
                    <CheckBox x:Name="FillersCheck" Content="Remove filler words (um, uh, erm…)"/>
                    <CheckBox x:Name="CommandsCheck" Content="Voice commands (“new line”, “new paragraph”)"/>
                    <CheckBox x:Name="CapsCheck" Content="Auto-capitalize sentences"/>
                    <CheckBox x:Name="PunctCheck" Content="Add final punctuation when missing"/>

                    <TextBlock Text="Behavior" Style="{StaticResource H2}" Margin="0,16,0,8"/>
                    <CheckBox x:Name="FlowBarCheck" Content="Show the Flow Bar at the bottom of the screen"/>
                    <CheckBox x:Name="SoundCheck" Content="Play a sound when dictation starts"/>
                    <CheckBox x:Name="StartupCheck" Content="Launch BONGA when Windows starts"/>

                    <TextBlock Text="AI cleanup (optional)" Style="{StaticResource H2}" Margin="0,16,0,4"/>
                    <TextBlock Style="{StaticResource Lbl}" Margin="0,0,0,10"
                               Text="After transcribing, send the text to Claude, OpenRouter or OpenAI to fix grammar, punctuation and phrasing. Your audio never leaves this PC — only the transcribed text is sent. Works fully offline when turned off."/>
                    <CheckBox x:Name="PolishCheck" Content="Improve transcription with AI cleanup"/>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Provider" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PolishProviderCombo" Width="280" HorizontalAlignment="Left" SelectionChanged="PolishProvider_Changed"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="API key" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <TextBox x:Name="PolishKeyBox" Style="{StaticResource DarkTextBox}" Width="360" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Model" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <TextBox x:Name="PolishModelBox" Style="{StaticResource DarkTextBox}" Width="360" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <TextBlock x:Name="PolishHint" Style="{StaticResource Lbl}" Margin="180,0,0,0"/>

                    <TextBlock Text="Cloud transcription (optional)" Style="{StaticResource H2}" Margin="0,18,0,4"/>
                    <TextBlock Style="{StaticResource Lbl}" Margin="0,0,0,10"
                               Text="Only used when Engine (above) is set to Cloud. Point at any OpenAI-compatible /audio/transcriptions endpoint. Leave blank to keep speech recognition fully on-device."/>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="API base URL" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <TextBox x:Name="ApiBaseBox" Style="{StaticResource DarkTextBox}" Width="360" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="API key" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <TextBox x:Name="ApiKeyBox" Style="{StaticResource DarkTextBox}" Width="360" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Cloud STT model" Width="180" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        <TextBox x:Name="SttModelBox" Style="{StaticResource DarkTextBox}" Width="360" HorizontalAlignment="Left"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Save settings" Style="{StaticResource AccentButton}" Click="SaveSettings_Click"/>
                        <TextBlock x:Name="SavedHint" Text="Saved ✓" Foreground="#FF9AF0B4" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
