<Window x:Class="VoiceFlow.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False" Focusable="False"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize">
    <Border x:Name="Pill" CornerRadius="20" Background="#F0181824"
            BorderBrush="#40FFFFFF" BorderThickness="1" Padding="16,9"
            Cursor="Hand" MouseLeftButtonDown="Pill_MouseDown">
        <Grid>
            <StackPanel x:Name="IdlePanel" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="IdleText" Text="BONGA" Foreground="#C0FFFFFF" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <Button x:Name="CloseBtn" Click="Close_Click" Cursor="Hand"
                        Width="16" Height="16" Margin="12,0,0,0" Padding="0"
                        Background="Transparent" BorderThickness="0" Foreground="#70FFFFFF"
                        ToolTip="Hide the Flow Bar. Bring it back from the tray icon or Settings.">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" CornerRadius="8" Background="Transparent">
                                <TextBlock Text="✕" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#30FFFFFF"/>
                                    <Setter Property="Foreground" Value="#F0FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <StackPanel x:Name="RecordPanel" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                <StackPanel x:Name="BarsPanel" Orientation="Horizontal" VerticalAlignment="Center" Height="26"/>
                <TextBlock x:Name="TimerText" Text="0:00" Foreground="#C0FFFFFF" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel x:Name="ProcessingPanel" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock x:Name="ProcessingText" Text="Transcribing…" Foreground="#C0FFFFFF" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="FlashText" Visibility="Collapsed" Foreground="#FF9AF0B4" FontSize="12" VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
